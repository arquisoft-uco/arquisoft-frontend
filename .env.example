# Copia este archivo como .env.development.local y completa los valores reales.
# NUNCA hagas commit de .env.development.local ni .env.production.local.
#
# En producción (Coolify, Docker) estas variables se inyectan como build args
# o variables de entorno del servidor — no se necesita ningún archivo .env.

# ── API ────────────────────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:8082/api

# ── Keycloak ───────────────────────────────────────────────────────────────────
VITE_KEYCLOAK_URL=http://localhost:8080/
VITE_KEYCLOAK_REALM=your-realm
VITE_KEYCLOAK_CLIENT_ID=your-client-id

# ── Dev bypass (solo para desarrollo local) ────────────────────────────────────
# Cambia a false para probar el flujo real de Keycloak.
VITE_AUTH_BYPASS=true
VITE_DEV_USERNAME=dev-user
# Roles separados por coma. Deben coincidir con los valores del enum Rol.
VITE_DEV_ROLES=estudiante,asesor_ficha,coordinador,representante_comite_curriculum,asesor,jurado,administrador,bibliotecario
